{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Spend Anything image manifest",
  "type": "object",
  "required": ["version", "generatedAt", "images"],
  "properties": {
    "version": { "type": "integer", "minimum": 1 },
    "generatedAt": { "type": "string" },
    "images": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["productId", "path", "alt", "sourceUrl", "license", "status"],
        "properties": {
          "productId": { "type": "string", "pattern": "^(lux|everyday)-[0-9]{6}$" },
          "path": { "type": "string" },
          "alt": { "type": "string" },
          "sourceUrl": { "type": "string" },
          "creator": { "type": "string" },
          "license": { "type": "string" },
          "licenseUrl": { "type": "string" },
          "status": { "enum": ["placeholder", "unreviewed", "approved", "rejected"] },
          "width": { "type": "integer", "minimum": 1 },
          "height": { "type": "integer", "minimum": 1 },
          "reviewedAt": { "type": "string" }
        }
      }
    }
  }
}
